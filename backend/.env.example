# Django Secret Key - Use a long, random string in production
DJANGO_SECRET_KEY=your-secret-key-here

# Debug Mode - Set to "false" in production
DJANGO_DEBUG=false

# Allowed Hosts - Comma separated list of domains your app is hosted on
DJANGO_ALLOWED_HOSTS=your-production-domain.up.railway.app,localhost,127.0.0.1

# Database Configuration
# Railway will automatically provide DATABASE_URL if you add a PostgreSQL database plugin
DATABASE_URL=postgresql://postgres:password@localhost:5432/village

# CORS Configuration - Comma separated list of origins allowed to make API requests (e.g., your frontend domains)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Google OAuth Configuration (Optional, for authentication)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
