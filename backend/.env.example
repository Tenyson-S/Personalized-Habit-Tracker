# Django Secret Key - Use a long, random string in production
DJANGO_SECRET_KEY=your-secret-key-here

# Debug Mode - Set to "false" in production
DJANGO_DEBUG=false

# Allowed Hosts - Comma separated list of domains your app is hosted on
DJANGO_ALLOWED_HOSTS=your-production-domain.up.railway.app

# Database Configuration
# Railway will automatically provide DATABASE_URL if you add a PostgreSQL database plugin
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# CORS Configuration - Comma separated list of origins allowed to make API requests (e.g., your frontend domains)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Google OAuth Configuration (Optional, for authentication)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Direct APK updates (upload the signed APK first, then update these values)
APP_UPDATE_VERSION_CODE=4
APP_UPDATE_VERSION_NAME=1.0.2
APP_UPDATE_APK_URL=https://downloads.example.com/stealth-track-1.0.2.apk
APP_UPDATE_SHA256=REPLACE_WITH_THE_APK_SHA256
APP_UPDATE_REQUIRED=false
APP_UPDATE_RELEASE_NOTES=Performance improvements and bug fixes.
